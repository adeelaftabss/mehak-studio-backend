# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
# Local: mongodb://localhost:27017/mehak-studio
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mehak-studio
MONGODB_URI=mongodb://localhost:27017/mehak-studio

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=mehak_token

# Admin bootstrap (used only by the seed script to create the first admin)
ADMIN_NAME=Adeel Aftab
ADMIN_EMAIL=mailadeelaftab@gmail.com
ADMIN_PASSWORD=ChangeThisPassword123!

# Email (Nodemailer via Gmail SMTP — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mailadeelaftab@gmail.com
SMTP_PASSWORD=replace_with_gmail_app_password
EMAIL_FROM="Mehak Studio <mailadeelaftab@gmail.com>"
NOTIFY_EMAIL=mailadeelaftab@gmail.com

# File uploads
MAX_FILE_SIZE_MB=15
